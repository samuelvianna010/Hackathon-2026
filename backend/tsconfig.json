{
    "compilerOptions": {
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "target": "es2020",
        "sourceMap": true,
        "outDir": "dist",
        "rootDir": ".",
        "allowImportingTsExtensions": true,
        "emitDeclarationOnly": true,
        "composite": true
    },
    "include": ["src/**/*"],
}